---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import PropertyCard from '../components/PropertyCard.astro';
import { getCollection } from 'astro:content';
import CallToAction from '../components/CallToAction.astro';
import { useTranslations } from '../i18n/ui';

const t = useTranslations('es');

const featuredProperties = await getCollection('properties', (entry) => entry.data.featured);
const allProperties = await getCollection('properties');
const zones = await getCollection('zones');

const homeFeaturedProperties = featuredProperties.slice(0, 3);
---

<Layout
  title="La Inmobiliaria — Propiedades Exclusivas en La Paz, BCS"
  description="Descubre nuestra selección curada de propiedades en La Paz, Baja California Sur. Tu hogar ideal te espera."
>
  <!-- Hero Section -->
  <Hero
    title={t('hero.title')}
    subtitle={t('hero.subtitle')}
    image="https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=1600&h=900&fit=crop&crop=entropy&auto=format"
    height="full"
    alignment="center"
    ctaText={t('hero.cta')}
    ctaLink="#destacadas"
  />

  <!-- Featured Properties Section -->
  <section id="destacadas" class="py-16 bg-primary-50">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-primary mb-4">
          {t('featured.title')}
        </h2>
        <p class="text-lg text-neutral max-w-2xl mx-auto">
          {t('featured.subtitle')}
        </p>
      </div>

      {homeFeaturedProperties.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {homeFeaturedProperties.map((property) => (
            <PropertyCard property={property} />
          ))}
        </div>
      ) : (
        <div class="text-center py-12">
          <p class="text-neutral-light">No hay propiedades destacadas en este momento.</p>
        </div>
      )}

      <div class="text-center mt-8">
        <a
          href="/properties"
          class="inline-flex items-center bg-primary text-white px-6 py-3 rounded-sm hover:bg-primary-soft transition-colors font-medium"
        >
          {t('featured.viewAll')}
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Zones Section -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-primary mb-4">
          {t('zones.title')}
        </h2>
        <p class="text-lg text-neutral max-w-2xl mx-auto">
          {t('zones.subtitle')}
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {zones.map((zone) => (
          <div class="group cursor-pointer">
            <div class="relative overflow-hidden rounded-lg elegant-shadow hover:elegant-shadow-lg transition-all duration-300">
              <img
                src={zone.data.image}
                alt={zone.data.title}
                class="w-full h-64 object-cover group-hover:scale-105 transition-transform duration-300"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-primary-900/80 to-transparent"></div>
              <div class="absolute bottom-0 left-0 right-0 p-6 text-white">
                <h3 class="text-xl font-semibold mb-2">{zone.data.title}</h3>
                <p class="text-white/90 text-sm line-clamp-2">{zone.data.description}</p>
              </div>
            </div>
            <a
              href={`/zones/${zone.slug}`}
              class="block mt-4 text-center text-primary hover:text-accent transition-colors font-medium"
            >
              {t('zones.explore')} {zone.data.title} →
            </a>
          </div>
        ))}
      </div>

      <div class="text-center mt-12">
        <a
          href="/zones"
          class="inline-flex items-center border-2 border-primary text-primary px-6 py-3 rounded-sm hover:bg-primary hover:text-white transition-colors font-medium"
        >
          {t('zones.viewAll')}
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Value Proposition Section -->
  <section class="py-16 bg-primary-900 text-white">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-accent/20 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-accent" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z"/>
              <path fill-rule="evenodd" d="M4 5a2 2 0 012-2 1 1 0 000 2H6a2 2 0 100 4h2a2 2 0 100 4h2a1 1 0 100 2 2 2 0 01-2 2H6a2 2 0 01-2-2V5z" clip-rule="evenodd"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-3">{t('value.curation.title')}</h3>
          <p class="text-primary-300">{t('value.curation.desc')}</p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-accent/20 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-accent" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-3">{t('value.quality.title')}</h3>
          <p class="text-primary-300">{t('value.quality.desc')}</p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-accent/20 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-accent" fill="currentColor" viewBox="0 0 20 20">
              <path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-3">{t('value.service.title')}</h3>
          <p class="text-primary-300">{t('value.service.desc')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Call to Action -->
  <CallToAction
    title={t('cta.title')}
    subtitle={t('cta.subtitle')}
  />
</Layout>
