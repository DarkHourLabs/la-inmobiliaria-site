---
import Layout from '../layouts/Layout.astro';
import HeroSecondary from '../components/HeroSecondary.astro';
import { getCollection } from 'astro:content';
import CallToAction from '../components/CallToAction.astro';

// Get agents data for team section
const agents = await getCollection('agents');
---

<Layout
  title="Sobre Nosotros — La Inmobiliaria"
  description="Conoce La Inmobiliaria, nuestra misión y el equipo de asesores expertos en bienes raíces en La Paz, BCS."
>
  <!-- Hero Section -->
  <HeroSecondary
    title="Sobre La Inmobiliaria"
    subtitle="Tu socio de confianza en bienes raíces en La Paz, Baja California Sur"
    height="h-96"
    alignment="left"
    backgroundImage="https://images.unsplash.com/photo-1666790676906-0295230c121d?w=1920&h=600&fit=crop&crop=entropy&auto=format"
    backgroundStyle="image"
  />

  <!-- Our Story Section -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold text-primary mb-6">Nuestra Historia</h2>
          <div class="space-y-4 text-neutral-dark leading-relaxed">
            <p>
              Nacimos con una visión clara: ser la inmobiliaria de referencia en La Paz, BCS — una ciudad que crece, que atrae inversión y que merece una oferta inmobiliaria a la altura de su potencial. Nos especializamos en propiedades cuidadosamente seleccionadas que combinan calidad, ubicación y valor de inversión.
            </p>
            <p>
              Comenzamos con una misión simple: acompañar a nuestros clientes no solo a comprar una propiedad, sino a encontrar el lugar que refleje su estilo de vida y sus metas. Hoy somos uno de los nombres más reconocidos en el mercado inmobiliario de La Paz.
            </p>
            <p>
              Creemos que cada propiedad tiene una historia, y cada cliente merece un asesor que entienda sus necesidades únicas. Nuestro equipo combina conocimiento profundo del mercado local con un compromiso genuino hacia la satisfacción del cliente.
            </p>
          </div>
        </div>
        <div class="relative">
          <img
            src="/images/about/story.jpg"
            alt="Our Story"
            class="rounded-lg elegant-shadow w-full"
          />
          <div class="absolute -bottom-6 -left-6 bg-primary text-white p-6 rounded-lg elegant-shadow-lg">
            <div class="text-3xl font-bold mb-2">10+</div>
            <div class="text-sm">Años de Experiencia</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Mission & Values Section -->
  <section class="py-16 bg-primary-faint">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-primary mb-4">Nuestra Misión y Valores</h2>
        <p class="text-neutral max-w-2xl mx-auto">
          Los principios que guían todo lo que hacemos
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="text-center">
          <div class="w-20 h-20 bg-white rounded-full flex items-center justify-center mx-auto mb-4 elegant-shadow">
            <svg class="w-10 h-10 text-primary" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-primary mb-3">Excelencia</h3>
          <p class="text-neutral">
            Mantenemos los más altos estándares en selección de propiedades, servicio y relaciones con clientes.
          </p>
        </div>

        <div class="text-center">
          <div class="w-20 h-20 bg-white rounded-full flex items-center justify-center mx-auto mb-4 elegant-shadow">
            <svg class="w-10 h-10 text-primary" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-primary mb-3">Transparencia</h3>
          <p class="text-neutral">
            La comunicación abierta y la guía honesta son fundamentales para construir relaciones duraderas.
          </p>
        </div>

        <div class="text-center">
          <div class="w-20 h-20 bg-white rounded-full flex items-center justify-center mx-auto mb-4 elegant-shadow">
            <svg class="w-10 h-10 text-primary" fill="currentColor" viewBox="0 0 20 20">
              <path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-primary mb-3">Cliente al Centro</h3>
          <p class="text-neutral">
            Tus necesidades y metas están en el centro de todo lo que hacemos, garantizando soluciones personalizadas.
          </p>
        </div>

        <div class="text-center">
          <div class="w-20 h-20 bg-white rounded-full flex items-center justify-center mx-auto mb-4 elegant-shadow">
            <svg class="w-10 h-10 text-primary" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M12 7a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0V8.414l-4.293 4.293a1 1 0 01-1.414 0L8 10.414l-4.293 4.293a1 1 0 01-1.414-1.414l5-5a1 1 0 011.414 0L11 10.586 14.586 7H12z" clip-rule="evenodd"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-primary mb-3">Innovación</h3>
          <p class="text-neutral">
            Adoptamos tecnología y enfoques creativos para ofrecer experiencias inmobiliarias excepcionales.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Statistics Section -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-primary mb-4">Nuestros Logros</h2>
        <p class="text-neutral max-w-2xl mx-auto">
          Números que reflejan nuestro compromiso con la excelencia
        </p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        <div class="text-center">
          <div class="text-4xl font-bold text-primary mb-2">500+</div>
          <div class="text-neutral-light">Propiedades Vendidas</div>
        </div>
        <div class="text-center">
          <div class="text-4xl font-bold text-primary mb-2">$500M+</div>
          <div class="text-neutral-light">En Ventas (MXN)</div>
        </div>
        <div class="text-center">
          <div class="text-4xl font-bold text-primary mb-2">98%</div>
          <div class="text-neutral-light">Satisfacción</div>
        </div>
        <div class="text-center">
          <div class="text-4xl font-bold text-primary mb-2">3</div>
          <div class="text-neutral-light">Asesores Expertos</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Team Section -->
  <section class="py-16 bg-primary-faint">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-primary mb-4">Conoce a Nuestro Equipo</h2>
        <p class="text-neutral max-w-2xl mx-auto">
          Los profesionales dedicados detrás de tu éxito inmobiliario
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {agents.map((agent) => (
          <div class="bg-white rounded-lg overflow-hidden elegant-shadow hover:elegant-shadow-lg transition-shadow">
            <img
              src={agent.data.image}
              alt={agent.data.name}
              class="w-full h-64 object-cover"
            />
            <div class="p-6">
              <h3 class="text-xl font-semibold text-primary-dark mb-1">{agent.data.name}</h3>
              <p class="text-primary-pale mb-4">{agent.data.jobTitle}</p>

              <p class="text-neutral-dark text-sm mb-4">{agent.data.bio}</p>

              {agent.data.experience && (
                <p class="text-neutral-light text-sm mb-4">
                  <strong>Experiencia:</strong> {agent.data.experience}
                </p>
              )}

              {agent.data.specialties && agent.data.specialties.length > 0 && (
                <div class="mb-4">
                  <p class="text-sm text-primary-pale font-medium mb-2">Especialidades:</p>
                  <div class="flex flex-wrap gap-2">
                    {agent.data.specialties.map((specialty) => (
                      <span class="px-2 py-1 bg-primary-faint text-primary-dark text-xs rounded-full">
                        {specialty}
                      </span>
                    ))}
                  </div>
                </div>
              )}

              {agent.data.languages && agent.data.languages.length > 0 && (
                <div class="mb-4">
                  <p class="text-sm text-primary-pale font-medium mb-2">Idiomas:</p>
                  <div class="flex flex-wrap gap-2">
                    {agent.data.languages.map((language) => (
                      <span class="text-sm text-neutral-dark">{language}</span>
                    ))}
                  </div>
                </div>
              )}

              <div class="border-t border-primary-faint pt-4 flex space-x-4">
                <a
                  href={`mailto:${agent.data.email}`}
                  class="text-primary hover:text-primary-soft transition-colors"
                >
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/>
                    <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/>
                  </svg>
                </a>
                <a
                  href={`tel:${agent.data.phone}`}
                  class="text-primary hover:text-primary-soft transition-colors"
                >
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
                  </svg>
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Call to Action -->
  <CallToAction
    title="¿Listo para Encontrar tu Propiedad Ideal?"
    subtitle="Déjanos guiarte en tu proceso inmobiliario con servicio personalizado y experiencia inigualable en La Paz, BCS."
  />
</Layout>