---
import '../styles/global.css'
import FooterCredit from '../components/FooterCredit.astro';
import { getLangFromUrl, useTranslations } from '../i18n/ui';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  canonical?: string;
  meta?: {
    title?: string;
    description?: string;
    keywords?: string[];
  };
}

const {
  title,
  description = "Propiedades exclusivas en La Paz, BCS",
  image = "/og-image.jpg",
  canonical,
  meta = {}
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const seoTitle = meta.title || title;
const seoDescription = meta.description || description;
const canonicalUrl = canonical || new URL(Astro.url.pathname, Astro.site).href;

// Build alternate lang URL
const currentPath = Astro.url.pathname;
const alternateLang = lang === 'es' ? 'en' : 'es';
const alternatePath = lang === 'es'
  ? `/en${currentPath === '/' ? '' : currentPath}`
  : currentPath.replace(/^\/en/, '') || '/';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={seoDescription} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{seoTitle}</title>
    <link rel="canonical" href={canonicalUrl} />
    {meta.keywords && meta.keywords.length > 0 && (
      <meta name="keywords" content={meta.keywords.join(', ')} />
    )}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={seoTitle} />
    <meta property="og:description" content={seoDescription} />
    <meta property="og:url" content={canonicalUrl} />
    {image && <meta property="og:image" content={image} />}
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={seoTitle} />
    <meta property="twitter:description" content={seoDescription} />
    <meta property="twitter:url" content={canonicalUrl} />
    {image && <meta property="twitter:image" content={image} />}
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Navigation Header -->
    <header class="bg-white border-b border-primary-faint sticky top-0 z-50">
      <nav class="container mx-auto px-4 py-4">
        <div class="flex items-center justify-between">
          <!-- Logo -->
          <a href={lang === 'en' ? '/en' : '/'} class="flex items-center space-x-2">
            <svg class="w-8 h-8 text-accent" fill="currentColor" viewBox="0 0 24 24">
              <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
            </svg>
            <span class="text-xl font-semibold text-primary">La Inmobiliaria</span>
          </a>

          <!-- Desktop Navigation -->
          <div class="hidden md:flex items-center space-x-8">
            <a href={lang === 'en' ? '/en' : '/'} class="text-neutral-dark hover:text-primary transition-colors">{t('nav.home')}</a>
            <a href={lang === 'en' ? '/en/properties' : '/properties'} class="text-neutral-dark hover:text-primary transition-colors">{t('nav.properties')}</a>
            <a href={lang === 'en' ? '/en/agents' : '/agents'} class="text-neutral-dark hover:text-primary transition-colors">{t('nav.agents')}</a>
            <a href={lang === 'en' ? '/en/zones' : '/zones'} class="text-neutral-dark hover:text-primary transition-colors">{t('nav.zones')}</a>
            <a href={lang === 'en' ? '/en/about' : '/about'} class="text-neutral-dark hover:text-primary transition-colors">{t('nav.about')}</a>
            <!-- Language Toggle -->
            <a href={alternatePath} class="text-sm text-neutral-dark hover:text-accent border border-neutral-300 hover:border-accent px-3 py-1 rounded-sm transition-colors">
              {alternateLang === 'en' ? 'EN' : 'ES'}
            </a>
            <a href={lang === 'en' ? '/en/contact' : '/contact'} class="bg-primary text-white px-4 py-2 rounded-sm hover:bg-primary-soft transition-colors">
              {t('nav.contact')}
            </a>
          </div>

          <!-- Mobile menu button -->
          <button id="mobile-menu-button" class="md:hidden p-2">
            <svg class="w-6 h-6 text-neutral-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>

        <!-- Mobile Navigation -->
        <div id="mobile-menu" class="hidden md:hidden pt-4 pb-2">
          <div class="flex flex-col space-y-2">
            <a href={lang === 'en' ? '/en' : '/'} class="text-neutral-dark hover:text-primary transition-colors py-2">{t('nav.home')}</a>
            <a href={lang === 'en' ? '/en/properties' : '/properties'} class="text-neutral-dark hover:text-primary transition-colors py-2">{t('nav.properties')}</a>
            <a href={lang === 'en' ? '/en/zones' : '/zones'} class="text-neutral-dark hover:text-primary transition-colors py-2">{t('nav.zones')}</a>
            <a href={lang === 'en' ? '/en/about' : '/about'} class="text-neutral-dark hover:text-primary transition-colors py-2">{t('nav.about')}</a>
            <a href={alternatePath} class="text-sm text-neutral-dark border border-neutral-300 px-3 py-1 rounded-sm inline-block">{alternateLang === 'en' ? 'English' : 'Español'}</a>
            <a href={lang === 'en' ? '/en/contact' : '/contact'} class="bg-primary text-white px-4 py-2 rounded-sm hover:bg-primary-soft transition-colors inline-block">
              {t('nav.contact')}
            </a>
          </div>
        </div>
      </nav>
    </header>

    <!-- Main Content -->
    <main class="flex-grow">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-primary-900 text-white py-12">
      <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
          <!-- Company Info -->
          <div class="col-span-1 md:col-span-2">
            <div class="flex items-center space-x-2 mb-4">
              <svg class="w-6 h-6 text-accent" fill="currentColor" viewBox="0 0 24 24">
                <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
              </svg>
              <span class="text-lg font-semibold">La Inmobiliaria</span>
            </div>
            <p class="text-primary-300 text-sm leading-relaxed">
              {t('footer.desc')}
            </p>
          </div>

          <!-- Quick Links -->
          <div>
            <h3 class="text-white font-semibold mb-4">{t('footer.quicklinks')}</h3>
            <ul class="space-y-2 text-sm">
              <li><a href={lang === 'en' ? '/en/properties' : '/properties'} class="text-primary-300 hover:text-accent transition-colors">{t('nav.properties')}</a></li>
              <li><a href={lang === 'en' ? '/en/zones' : '/zones'} class="text-primary-300 hover:text-accent transition-colors">{t('nav.zones')}</a></li>
              <li><a href={lang === 'en' ? '/en/about' : '/about'} class="text-primary-300 hover:text-accent transition-colors">{t('nav.about')}</a></li>
              <li><a href={lang === 'en' ? '/en/contact' : '/contact'} class="text-primary-300 hover:text-accent transition-colors">{t('nav.contact')}</a></li>
            </ul>
          </div>

          <!-- Contact -->
          <div>
            <h3 class="text-white font-semibold mb-4">{t('footer.contact')}</h3>
            <ul class="space-y-2 text-sm text-primary-300">
              <li class="flex items-center space-x-2">
                <svg class="w-4 h-4 text-accent" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/>
                  <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/>
                </svg>
                <span>contacto@lainmobiliaria.mx</span>
              </li>
              <li class="flex items-center space-x-2">
                <svg class="w-4 h-4 text-accent" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
                </svg>
                <span>+52 (612) 123-4567</span>
              </li>
              <li class="flex items-center space-x-2">
                <svg class="w-4 h-4 text-accent" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
                </svg>
                <span>La Paz, Baja California Sur, México</span>
              </li>
            </ul>
          </div>
        </div>

        <div class="border-t border-primary-800 mt-8 pt-8 text-center text-sm text-primary-400">
          <p>&copy; {new Date().getFullYear()} La Inmobiliaria. {t('footer.copyright')}</p>
        </div>
      </div>
    </footer>

    <script>
      const mobileMenuButton = document.getElementById('mobile-menu-button');
      const mobileMenu = document.getElementById('mobile-menu');
      if (mobileMenuButton && mobileMenu) {
        mobileMenuButton.addEventListener('click', () => {
          mobileMenu.classList.toggle('hidden');
        });
      }
    </script>
  </body>
</html>
